#!/usr/bin/env bash

if [[ "${DJANGO_AUTO_MIGRATE:-true}" == "true" ]]; then
	python manage.py migrate
fi

default_flags=(
	-w 2
	-k gthread
	-b 0.0.0.0:8000
)

if [[ -n "$GUNICORN_FLAGS" ]]; then
	mapfile -t flags < <(xargs -n 1 <<< "$GUNICORN_FLAGS")
else
	flags=("${default_flags[@]}")
fi

exec gunicorn "${flags[@]}" project.wsgi:application
